# ====== Rules for running rMATS from bam files =================================

# gathering results
rule gathering_bams_groups:
    input:
        PROJ + "/report/" + PROJ + "_" + INDEXES[0] + "_results.tsv"
    output:
        PROJ + "/rmats/{compgroups}_S1.txt",
        PROJ + "/rmats/{compgroups}_S2.txt",
        "{compgroups}_bams.tsv",
        PROJ + "/rmats/{compgroups}_palette.txt"
    params:
        job_name = "{compgroups}_rmats_bams_groups",
        project = PROJ + "/bams",
        mygroup  = "{compgroups}",
        mycols   = lambda w: " ".join(f"{k}={v}" for k, v in COLS_DICT.items()),
        mysamps  = SAM_GRPS,
        script   = "workflow/scripts/rmats_groups.R"
    resources:
        memory   = lambda wildcards, input: memory_estimator(input, 1, 1) # multiplier, min, max, unit=GB
    message:
        "getting final rmats_bams_groups  {wildcards.compgroups}"
    threads: 
        1
    shell:
        """
        Rscript {params.script} "{params.project}" "{params.mygroup}" "{params.mysamps}" "{params.mycols}" "{output}"
        """
  

# run rmats
rule run_rmats:
    input:
        S1 = PROJ + "/rmats/{compgroups}_S1.txt",
        S2 = PROJ + "/rmats/{compgroups}_S2.txt"
    output:
        SE   = PROJ + "/rmats/{compgroups}/SE.MATS.JC.txt",
        MXE  = PROJ + "/rmats/{compgroups}/MXE.MATS.JC.txt",
        A3SS = PROJ + "/rmats/{compgroups}/A3SS.MATS.JC.txt",
        A5SS = PROJ + "/rmats/{compgroups}/A5SS.MATS.JC.txt",
        RI   = PROJ + "/rmats/{compgroups}/RI.MATS.JC.txt"
    params:
        job_name  = "{compgroups}_rmats",
        outdir    = PROJ + "/rmats/{compgroups}",
        outdirtmp = PROJ + "/rmats/{compgroups}/tmp",
        gtf       = GTF,
        args      = CMD_PARAMS["rmats"]
    resources:
        memory = lambda wildcards, input: memory_estimator(input, 10, 30)
    threads: 12
    shell:
        """
        rm -rf {params.outdirtmp}
        mkdir -p {params.outdirtmp}
        
        rmats.py --b1 {input.S1} --b2 {input.S2} \
        --gtf {params.gtf} \
        --od {params.outdir} \
        --tmp {params.outdirtmp} \
        --nthread {threads} \
        {params.args}
        
        rm -rf {params.outdirtmp}
        """
                    
# filter and make bar plots, gene lists and sashimi plots                    
rule rmats_plot:
    input:
        jc = expand(
            PROJ + "/rmats/{compgroups}/{splice_type}.MATS.JC.txt",
            compgroups = GRPS_UNIQ,
            splice_type = config["SPLICE_TYPES"]
        )
    output:
        pdf = PROJ + "_{compgroups}_summary_plots.pdf",
        inpos = PROJ + "/rmats/{compgroups}_more_inclusion_pos.txt",
        inneg = PROJ + "/rmats/{compgroups}_more_inclusion_neg.txt",
        skpos = PROJ + "/rmats/{compgroups}_more_skipping_pos.txt",
        skneg = PROJ + "/rmats/{compgroups}_more_skipping_neg.txt"
    params:
        job_name        = "{compgroups}_rmats_plot",
        proj            = PROJ,
        tc              = "{compgroups}",
        min_count       = CMD_PARAMS["min_count"],
        max_fdr         = CMD_PARAMS["max_FDR"],
        max_incdiff     = CMD_PARAMS["max_IncDifference"],
        splice_type     = " ".join(config["SPLICE_TYPES"]),
        script          = "workflow/scripts/rMATS_plots.R",
        num_plots       = SASHIMI_PARAMS["num_plots"]
    resources:
        memory   = lambda wildcards, input: memory_estimator(input, 1, 1, 20) # multiplier, min, max, unit=GB
    threads: 
        1
    shell:
        """
        Rscript {params.script} \
            "{params.proj}" \
            "{params.tc}" \
            "{params.min_count}" \
            "{params.max_fdr}" \
            "{params.max_incdiff}" \
            "{params.splice_type}" \
            "{params.num_plots}" \
            "{output.pdf}" 
            
        """
        
# Generate sashimi plots as PNGs
rule rmats_sashimi:
    input:
        jc = expand(
            PROJ + "/rmats/{{compgroups}}/{splice_type}.MATS.JC.txt",
            splice_type = config["SPLICE_TYPES"]
        ),
        pos = PROJ + "/rmats/{compgroups}_{direction}_pos.txt",
        neg = PROJ + "/rmats/{compgroups}_{direction}_neg.txt",
        bams = "{compgroups}_bams.tsv",
        palette = PROJ + "/rmats/{compgroups}_palette.txt"
    output:
        directory("rMATS_sashimi_{compgroups}_{direction}_pngs")
    params:
        job_name        = "{compgroups}_{direction}_rmats_sashimi",
        gtf          = GTF,
        sashimi_args = SASHIMI_PARAMS["args"]
    resources:
        memory = lambda wildcards, input: memory_estimator(input, 1, 1, 20)
    threads: 1
    shell:
        """
        mkdir -p {output}
    
        while IFS=$'\t' read -r col1 col2; do
            python workflow/scripts/ggsashimi_Claude.py \
                -b {input.bams} \
                -c $col1 \
                -g {params.gtf} \
                -P {input.palette} \
                -o {output}/$col2 \
                -C 3 {params.sashimi_args} \
                --out-strand plus \
                --out-format png || echo "WARNING: ggsashimi failed for $col1 $col2, skipping"
        done < {input.pos}
    
        while IFS=$'\t' read -r col1 col2; do
            python workflow/scripts/ggsashimi_Claude.py \
                -b {input.bams} \
                -c $col1 \
                -g {params.gtf} \
                -P {input.palette} \
                -o {output}/$col2 \
                -C 3 {params.sashimi_args} \
                --out-strand minus \
                --out-format png || echo "WARNING: ggsashimi failed for $col1 $col2, skipping"
        done < {input.neg}
        """

rule rmats_png_to_pdf:
    input:
        "rMATS_sashimi_{compgroups}_{direction}_pngs"
    output:
        PROJ + "_{compgroups}_{direction}.pdf"
    params:
        job_name = "{compgroups}_{direction}_sashimi_pdf",
        script     = "workflow/scripts/pngToPDF.R",
        chunk_size = 4,
        title      = "{compgroups} {direction}"
    resources:
        memory = lambda wildcards, input: memory_estimator(input, 10, 4, 200)
    shell:
        "Rscript {params.script} {input} {params.chunk_size} '{params.title}' {output}"        
        

